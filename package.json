{
  "name": "react-mvvm",
  "private": true,
  "version": "1.0.0",
  "packageManager": "pnpm@10.18.3",
  "devDependencies": {
    "@biomejs/biome": "^2.3.5",
    "husky": "^9.1.7",
    "lerna": "^9.0.0",
    "typescript": "^5.9.3"
  },
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "pnpm -r run build",
    "lint": "pnpm exec biome check .",
    "lint:fix": "pnpm exec biome lint --write",
    "format": "pnpm exec biome format --write",
    "prepare": "husky"
  }
}
